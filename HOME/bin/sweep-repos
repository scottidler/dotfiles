#!/usr/bin/env bash
# sweep-repos: run cargo-sweep on every Rust project found two directories
# deep under a root (default ~/repos), enumerating repo-root Cargo.toml files
# instead of `cargo sweep -r <root>` -- which stalls walking into target/ and
# any large non-Rust subtrees. `find -maxdepth 3` reads only <root>/<org>/<repo>
# dir listings and never descends into target/ (depth 4+), so it is fast.
#
# Managed by scottidler/dotfiles via manifest (link: HOME -> $HOME). Edit the
# repo copy, not the ~/bin symlink. The weekly cron is the `sweep-repos-cron`
# entry in manifest.yml's script: section.
set -euo pipefail

DAYS=14
ROOT="${HOME}/repos"
DRY_RUN=()

usage() {
  cat >&2 <<'EOF'
usage: sweep-repos [--time DAYS] [--root DIR] [--dry-run]
  --time DAYS   remove build artifacts older than DAYS (default: 14)
  --root DIR    search root (default: ~/repos)
  --dry-run     report only; delete nothing
Enumerates <root>/<org>/<repo>/Cargo.toml and runs cargo-sweep per repo.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --time)    DAYS="$2"; shift 2 ;;
    --root)    ROOT="$2"; shift 2 ;;
    --dry-run) DRY_RUN=(--dry-run); shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "sweep-repos: unknown arg: $1" >&2; usage; exit 2 ;;
  esac
done

command -v cargo-sweep >/dev/null 2>&1 || { echo "sweep-repos: cargo-sweep not installed" >&2; exit 1; }

echo "sweep-repos: root=${ROOT} time=${DAYS}d${DRY_RUN:+ (dry-run)}" >&2

# Repo-root manifests live exactly two dirs deep: <root>/<org>/<repo>/Cargo.toml.
# -maxdepth 3 stops find from descending into target/ (depth 4+) -> fast, no stall.
count=0
find "${ROOT}" -mindepth 3 -maxdepth 3 -name Cargo.toml -type f -print0 \
  | sort -z \
  | while IFS= read -r -d '' manifest; do
      repo="$(dirname "${manifest}")"
      # Skip repos that were never built locally (no target/) to keep the log clean.
      [[ -d "${repo}/target" ]] || continue
      count=$((count + 1))
      echo "sweep-repos: [${count}] ${repo}" >&2
      cargo sweep "${DRY_RUN[@]}" --time "${DAYS}" "${repo}" \
        || echo "sweep-repos: WARN sweep failed for ${repo}" >&2
    done

echo "sweep-repos: done" >&2
