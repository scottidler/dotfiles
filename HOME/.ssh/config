ServerAliveInterval 55

Host desk.lan
    HostName desk.lan

# Travel-mode X11: jump through Tailscale SSH, then hop to real OpenSSH on
# desk's loopback. Tailscale SSH itself doesn't implement X11 forwarding
# (tailscale/tailscale#5160), so the inner OpenSSH connection is what carries
# the X11 channel. ACL-gating still applies on the jump.
Host desk.ts
    HostName 127.0.0.1
    ProxyJump saidler@desk.taild2b9be.ts.net
    User saidler
    IdentityFile ~/.ssh/identities/home/id_ed25519
    ForwardX11 yes
    ForwardX11Trusted yes

# Default GitHub configuration for personal repositories
Host github.com
    HostName github.com
    PreferredAuthentications publickey
    IdentityFile ~/.ssh/identities/home/id_ed25519
    IdentitiesOnly yes
    User git

Host nas.lan
    IdentityFile ~/.ssh/identities/home/id_ed25519
    ForwardAgent no
    ForwardX11 no
    ForwardX11Trusted no
    User saidler

Host *.lan *.wan *.localdomain
    IdentityFile ~/.ssh/identities/home/id_ed25519
    ForwardAgent yes
    ForwardX11 yes
    ForwardX11Trusted yes
    User saidler

Host nixos
    IdentityFile ~/.ssh/identities/home/id_ed25519
    ForwardAgent yes
    ForwardX11 yes
    User saidler
