# vim: filetype=sh

if [ -n "$DEBUG" ]; then
    PS4=':${LINENO}+'
    set -x
fi

function dots() {
    local dotfiles=$(dirname $(dirname $(realpath ~/.shell-functions)))
    cd "$dotfiles"; pwd; git pull
    . ~/.zshrc
}

if [ -d ~/.shell-functions.d/ ]; then
    for f in ~/.shell-functions.d/*; do . $f; done
fi
